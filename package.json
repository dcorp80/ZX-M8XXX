{
  "name": "zx-m8xxx-ladder",
  "version": "0.1.0",
  "description": "ZX Spectrum emulator and debugger for the browser, forked from Bedazzle's ZX-M8XXX",
  "keywords": [
    "zx-spectrum",
    "emulator",
    "debugger",
    "z80",
    "8-bit",
    "retro-computing",
    "reverse-engineering"
  ],
  "homepage": "https://github.com/dcorp80/ZX-M8XXX-ladder#readme",
  "bugs": {
    "url": "https://github.com/dcorp80/ZX-M8XXX-ladder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcorp80/ZX-M8XXX-ladder.git",
    "directory": "."
  },
  "upstream": {
    "name": "Bedazzle/ZX-M8XXX",
    "url": "https://github.com/Bedazzle/ZX-M8XXX",
    "baseline": "v0.9.37"
  },
  "license": "GPL-3.0",
  "author": "Bedazzle (upstream: ZX-M8XXX)",
  "contributors": [],
  "type": "module",
  "main": "index.html",
  "private": true,
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean:reports": "rm -rf reports .vitest-reports",
    "test": "npm run test:headless && npm run test:unit && npm run test:report",
    "test:unit": "vitest run --project unit --coverage --outputFile.blob=.vitest-reports/unit.json",
    "test:headless": "vitest run --project headless --outputFile.blob=.vitest-reports/headless.json",
    "test:report": "vitest run --merge-reports=.vitest-reports --coverage --reporter=html --outputFile.html=reports/index.html",
    "test:report:ci": "vitest run --merge-reports=.vitest-reports --coverage --reporter=junit --reporter=github-actions --outputFile.junit=reports/junit.xml",
    "test:update-hashes": "node tests/headless/update-hashes.js",
    "test:verify-hashes": "node tests/headless/update-hashes.js --verify"
  },
  "dependencies": {
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.37.5",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
